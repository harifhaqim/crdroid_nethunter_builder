# NetHunter additions for POCO X5 5G / Redmi Note 12 5G (stone/moonstone/sunstone)
# SM6375 (Snapdragon 695 5G) — Linux 5.4.x
# This file is MERGED over stone_defconfig via merge_config.sh — NOT a standalone defconfig.

# ── 32-bit compat para apps de Android ───────────────────────────────────────
# Sin esto, olddefconfig pregunta interactivamente y el build se cuelga.
CONFIG_COMPAT=y
CONFIG_KUSER_HELPERS=y
CONFIG_COMPAT_VDSO=y

# ── Module support ───────────────────────────────────────────────────────────
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_UNLOAD=y
CONFIG_MODVERSIONS=y
CONFIG_MODULE_SIG=n

# ── USB Gadget / NetHunter modes ─────────────────────────────────────────────
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_RNDIS=y
CONFIG_USB_CONFIGFS_NCM=y
CONFIG_USB_CONFIGFS_MASS_STORAGE=y
CONFIG_USB_CONFIGFS_F_FS=y
CONFIG_USB_CONFIGFS_F_HID=y
CONFIG_USB_RAW_GADGET=y
# CONFIG_USB_G_ANDROID is not set

# ── HID attacks (BadUSB / ghost keyboard) ────────────────────────────────────
CONFIG_HID=y
CONFIG_HIDRAW=y
CONFIG_USB_HID=y
CONFIG_HID_GENERIC=y

# ── Bluetooth attacks + external adapter support ─────────────────────────────
CONFIG_BT=y
CONFIG_BT_BREDR=y
CONFIG_BT_LE=y
CONFIG_BT_HCIBTUSB=y
CONFIG_BT_HCIBTUSB_RTL=y
CONFIG_BT_RFCOMM=y
CONFIG_BT_RFCOMM_TTY=y
CONFIG_BT_BNEP=y
CONFIG_BT_HIDP=y
CONFIG_BT_HCIUART=y

# ── Wireless stack base ───────────────────────────────────────────────────────
CONFIG_CFG80211=y
CONFIG_CFG80211_WEXT=y
CONFIG_CFG80211_WEXT_EXPORT=y
CONFIG_WIRELESS_EXT=y
CONFIG_WEXT_PRIV=y
CONFIG_WEXT_SPY=y
CONFIG_MAC80211=y
CONFIG_MAC80211_MESH=y
CONFIG_RFKILL=y

# ── Realtek drivers ──────────────────────────────────────────────────────────
# rtl8188eus y rtl88x2bu se compilan OUT-OF-TREE en step 07 (sus Makefiles
# upstream son out-of-tree-only y rompen con kbuild + O= separado). NO
# añadimos sus CONFIG_RTL aquí porque ya no están en el árbol del kernel.
# Solo dejamos in-tree habilitado el vendor flag base.
CONFIG_WLAN_VENDOR_REALTEK=y

# ── Netfilter (required by NetHunter tools) ───────────────────────────────────
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_CONNTRACK_MARK=y
CONFIG_NF_NAT=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_NAT=y
CONFIG_IP6_NF_IPTABLES=y

# ── Crypto (Kismet, Wireshark, wireless tools) ────────────────────────────────
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_ARC4=y
CONFIG_CRYPTO_MICHAEL_MIC=y
CONFIG_CRYPTO_CMAC=y
CONFIG_CRYPTO_GCM=y

# ── LTO: Thin only (Full causes link errors on SM6375/5.4 with QCACLD) ────────
# El master CONFIG_LTO_CLANG debe estar primero o olddefconfig pregunta
# interactivamente "1.None / 2.LTO_CLANG" y el build se cuelga.
CONFIG_LTO=y
CONFIG_LTO_CLANG=y
CONFIG_THINLTO=y
CONFIG_LTO_CLANG_THIN=y
# CONFIG_LTO_CLANG_FULL is not set
# CFI requires extra QCACLD patches; mantener apagado para evitar link errors.
# CONFIG_CFI_CLANG is not set
# CONFIG_SHADOW_CALL_STACK is not set
CONFIG_RELR=y

# ── KernelSU Next ─ moved to config/stone_ksu.config (only merged when KSU=ksunext)

# ── Kernel branding ──────────────────────────────────────────────────────────
# Build date is appended at compile time via localversion-build file
CONFIG_LOCALVERSION="-crDroid-nethunter-ms"
# CONFIG_LOCALVERSION_AUTO is not set

# ── GKI / QGKI compatibility ─────────────────────────────────────────────────
# Allow out-of-tree modules without ABI restriction
# CONFIG_TRIM_UNUSED_KSYMS is not set
CONFIG_MODULE_SIG=n
CONFIG_MODULE_SIG_FORCE=n

# ── Clang 17 build fixes ──────────────────────────────────────────────────────
# qcom_scm.c has two init calls (subsys_initcall + early_initcall); cannot be =m
CONFIG_QCOM_SCM=y
