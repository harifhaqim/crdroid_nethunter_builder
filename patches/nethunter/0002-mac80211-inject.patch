diff --git a/net/mac80211/cfg.c b/net/mac80211/cfg.c
index 2f0c27ecb..36239ffe6 100644
--- a/net/mac80211/cfg.c
+++ b/net/mac80211/cfg.c
@@ -788,7 +788,7 @@ static int ieee80211_set_monitor_channel(struct wiphy *wiphy,
 			ret = ieee80211_vif_use_channel(sdata, chandef,
 					IEEE80211_CHANCTX_EXCLUSIVE);
 		}
-	} else if (local->open_count == local->monitors) {
+	} else /* NetHunter: allow channel change with normal interfaces present */ {
 		local->_oper_chandef = *chandef;
 		ieee80211_hw_config(local, 0);
 	}
diff --git a/net/mac80211/tx.c b/net/mac80211/tx.c
index f8d72f3e4..1321b5ade 100644
--- a/net/mac80211/tx.c
+++ b/net/mac80211/tx.c
@@ -810,11 +810,16 @@ ieee80211_tx_h_sequence(struct ieee80211_tx_data *tx)
 
 	/*
 	 * Packet injection may want to control the sequence
-	 * number, if we have no matching interface then we
-	 * neither assign one ourselves nor ask the driver to.
+	 * number, so if an injected packet is found, skip
+	 * renumbering it. Also set NO_ACK to avoid retries.
+	 * NetHunter injection patch.
 	 */
-	if (unlikely(info->control.vif->type == NL80211_IFTYPE_MONITOR))
+	if (unlikely((info->flags & IEEE80211_TX_CTL_INJECTED) &&
+	   !(tx->sdata->u.mntr.flags & MONITOR_FLAG_COOK_FRAMES))) {
+		if (!ieee80211_has_morefrags(hdr->frame_control))
+			info->flags |= IEEE80211_TX_CTL_NO_ACK;
 		return TX_CONTINUE;
+	}
 
 	if (unlikely(ieee80211_is_ctl(hdr->frame_control)))
 		return TX_CONTINUE;
@@ -2030,7 +2035,10 @@ void ieee80211_xmit(struct ieee80211_sub_if_data *sdata,
 		}
 	}
 
-	ieee80211_set_qos_hdr(sdata, skb);
+	/* NetHunter: skip QoS header overwrite for injected monitor frames */
+	if (likely(!(info->flags & IEEE80211_TX_CTL_INJECTED) ||
+	    info->control.vif->type != NL80211_IFTYPE_MONITOR))
+		ieee80211_set_qos_hdr(sdata, skb);
 	ieee80211_tx(sdata, sta, skb, false, txdata_flags);
 }
 
diff --git a/net/wireless/chan.c b/net/wireless/chan.c
index dd8bb88a6..db0f58846 100644
--- a/net/wireless/chan.c
+++ b/net/wireless/chan.c
@@ -1164,8 +1164,7 @@ int cfg80211_set_monitor_channel(struct cfg80211_registered_device *rdev,
 {
 	if (!rdev->ops->set_monitor_channel)
 		return -EOPNOTSUPP;
-	if (!cfg80211_has_monitors_only(rdev))
-		return -EBUSY;
+	/* NetHunter: allow channel change even when other interfaces exist */
 
 	return rdev_set_monitor_channel(rdev, chandef);
 }
