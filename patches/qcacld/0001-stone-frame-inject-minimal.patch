--- a/drivers/staging/qcacld-3.0/core/hdd/src/wlan_hdd_main.c
+++ b/drivers/staging/qcacld-3.0/core/hdd/src/wlan_hdd_main.c
@@ -2930,6 +2930,15 @@ static int __hdd_mon_open(struct net_device *dev)
 					  PLD_BUS_WIDTH_VERY_HIGH);
 	}
 
+	/* Force carrier ON in monitor mode so aireplay-ng / pcap raw sockets
+	 * can deliver TX skbs to ndo_start_xmit. Without this wlan0 stays
+	 * NO-CARRIER permanently and the kernel drops every TX before xmit.
+	 */
+	netif_carrier_on(dev);
+	netif_tx_start_all_queues(dev);
+	printk(KERN_INFO "STONE_INJECT: monitor open carrier=ON dev=%s\n",
+	       dev->name);
+
 	return ret;
 }
 
