+		resp->vdev_id = vdev_id;
+		resp->status = QDF_STATUS_SUCCESS;
+		wlan_vdev_mlme_sm_deliver_evt(iface->vdev,
+					      WLAN_VDEV_SM_EV_DOWN,
+					      sizeof(*resp), resp);
+	}
 	iface->vdev_active = false;
 }
 
