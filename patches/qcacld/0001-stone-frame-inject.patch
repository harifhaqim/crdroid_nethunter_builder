diff --git a/drivers/staging/qcacld-3.0/core/wma/src/wma_frame_inject.c b/drivers/staging/qcacld-3.0/core/wma/src/wma_frame_inject.c
new file mode 100644
index 000000000..f02b177a2
--- /dev/null
+++ b/drivers/staging/qcacld-3.0/core/wma/src/wma_frame_inject.c
@@ -0,0 +1,2118 @@
